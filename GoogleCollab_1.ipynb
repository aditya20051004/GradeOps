#install the necessary requirements


#loading of models
from transformers import (
    Qwen2VLForConditionalGeneration,
    AutoProcessor,
    NougatProcessor,
    VisionEncoderDecoderModel
)
import torch
from PIL import Image
import io
import base64

# Load Qwen2-VL
print("🔄 Loading Qwen2-VL-2B...")
qwen_model = Qwen2VLForConditionalGeneration.from_pretrained(
    "Qwen/Qwen2-VL-2B-Instruct",
    torch_dtype=torch.float16,
    device_map="auto"
)
qwen_processor = AutoProcessor.from_pretrained(
    "Qwen/Qwen2-VL-2B-Instruct"
)
print("✅ Qwen2-VL loaded!")

# Load Nougat
print("🔄 Loading Nougat...")
nougat_processor = NougatProcessor.from_pretrained(
    "facebook/nougat-base"
)
nougat_model = VisionEncoderDecoderModel.from_pretrained(
    "facebook/nougat-base"
).to("cuda")
print("✅ Nougat loaded!")


#creating api
from flask import Flask, request, jsonify
from pyngrok import ngrok
import threading

app = Flask(__name__)

# ── Qwen2-VL OCR ──────────────────────
def run_qwen(image):
    messages = [{
        "role": "user",
        "content": [
            {"type": "image", "image": image},
            {"type": "text", "text": "Extract all text from this exam paper accurately including all answers and questions."}
        ]
    }]
    
    text = qwen_processor.apply_chat_template(
        messages,
        tokenize=False,
        add_generation_prompt=True
    )
    
    inputs = qwen_processor(
        text=[text],
        images=[image],
        return_tensors="pt"
    ).to("cuda")
    
    with torch.no_grad():
        output_ids = qwen_model.generate(
            **inputs,
            max_new_tokens=1024
        )
    
    generated_ids = [
        output_ids[len(input_ids):]
        for input_ids, output_ids
        in zip(inputs.input_ids, output_ids)
    ]
    
    return qwen_processor.batch_decode(
        generated_ids,
        skip_special_tokens=True
    )[0]

# ── Nougat OCR ────────────────────────
def run_nougat(image):
    pixel_values = nougat_processor(
        image,
        return_tensors="pt"
    ).pixel_values.to("cuda")
    
    outputs = nougat_model.generate(
        pixel_values,
        min_length=1,
        max_new_tokens=3096,
        bad_words_ids=[[
            nougat_processor.tokenizer.unk_token_id
        ]]
    )
    
    return nougat_processor.batch_decode(
        outputs,
        skip_special_tokens=True
    )[0]

# ── API Endpoints ─────────────────────
@app.route('/health', methods=['GET'])
def health():
    return jsonify({
        "status": "running ✅",
        "models": ["Qwen2-VL-2B", "Nougat"],
        "device": "T4 GPU"
    })

@app.route('/ocr', methods=['POST'])
def qwen_ocr():
    try:
        data = request.json
        image_base64 = data.get('image_base64', '')
        image_data = base64.b64decode(image_base64)
        image = Image.open(io.BytesIO(image_data)).convert("RGB")
        
        print("🤖 Running Qwen2-VL...")
        text = run_qwen(image)
        print(f"✅ Extracted {len(text)} chars")
        
        return jsonify({
            "extracted_text": text,
            "method": "qwen2_vl_2b",
            "confidence": "very_high"
        })
    except Exception as e:
        return jsonify({"error": str(e)}), 500

@app.route('/nougat', methods=['POST'])
def nougat_ocr():
    try:
        data = request.json
        image_base64 = data.get('image_base64', '')
        image_data = base64.b64decode(image_base64)
        image = Image.open(io.BytesIO(image_data)).convert("RGB")
        
        print("🤖 Running Nougat...")
        text = run_nougat(image)
        print(f"✅ Extracted {len(text)} chars")
        
        return jsonify({
            "extracted_text": text,
            "method": "nougat_meta",
            "confidence": "high"
        })
    except Exception as e:
        return jsonify({"error": str(e)}), 500

# ── Start Server ──────────────────────
def run_flask():
    app.run(port=5000, debug=False)

thread = threading.Thread(target=run_flask)
thread.daemon = True
thread.start()
print("✅ Flask server started!")


